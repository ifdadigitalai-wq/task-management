generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  image          String?
  phone          String?
  department     String?
  password       String
  role           Role      @default(EMPLOYEE)
  mustResetPassword Boolean   @default(true)
  joinedAt       DateTime?
  createdAt      DateTime      @default(now())
  assignedTasks  Task[]        @relation("AssignedTo")
  delegatedTasks Task[]        @relation("DelegatedBy")
  notifications  Notification[]
  updateComments UpdateComment[]
}

model Task {
  id            String        @id @default(cuid())
  title         String
  description   String?
  status        TaskStatus    @default(PENDING)
  priority      Priority      @default(MEDIUM)
  progress      Int           @default(0)
  tag           String?
  dueDate       DateTime?
  targetDate    DateTime?
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  assignedToId  String?
  delegatedById String?
  assignedTo    User?         @relation("AssignedTo",  fields: [assignedToId],  references: [id])
  delegatedBy   User?         @relation("DelegatedBy", fields: [delegatedById], references: [id])
  templateId    String?
  template      TaskTemplate? @relation(fields: [templateId], references: [id])
  updates       TaskUpdate[]
}

model TaskTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  priority    Priority @default(MEDIUM)
  tag         String?
  tasks       Task[]
  createdAt   DateTime @default(now())
}

model Holiday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  createdAt DateTime @default(now())
}

model Activity {
  id        String   @id @default(cuid())
  action    String
  taskId    String?
  userId    String?
  createdAt DateTime @default(now())
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  isSeen    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model TaskUpdate {
  id        String          @id @default(cuid())
  taskId    String
  task      Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  remark    String
  files     String[]
  images    String[]
  hasVoice  Boolean         @default(false)
  createdAt DateTime        @default(now())
  comments  UpdateComment[]
}

model UpdateComment {
  id        String     @id @default(cuid())
  updateId  String
  update    TaskUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)
  text      String
  authorId  String
  author    User       @relation(fields: [authorId], references: [id])
  createdAt DateTime   @default(now())
}
