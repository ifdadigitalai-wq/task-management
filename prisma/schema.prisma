generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  TEAM_LEADER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  RESIGNED
  ON_LEAVE
}

enum Frequency {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum EventType {
  LEAVE
  EVENT
  OFFICIAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UpdateType {
  COMMENT
  STATUS_CHANGE
  ASSIGNMENT
  TIME_LOG
}

model User {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  passwordHash      String
  role              Role           @default(EMPLOYEE)
  status            UserStatus     @default(ACTIVE)
  department        String?
  departmentId      String?
  departmentObj     Department?    @relation(fields: [departmentId], references: [id])
  team              String?
  jobTitle          String?
  avatarUrl         String?
  phone             String?
  joinedAt          DateTime?
  isActive          Boolean        @default(true)
  mustResetPassword Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  assignedTasks     Task[]         @relation("AssignedTo")
  createdTasks      Task[]         @relation("CreatedBy")
  updates           TaskUpdate[]
  comments          TaskComment[]
  updateComments    TaskUpdateComment[]
  timers            TaskTimer[]
  notifications     Notification[]
  activities        Activity[]
  templates         TaskTemplate[]
  calendarEvents    CalendarEvent[]
}

model Task {
  id               String         @id @default(cuid())
  title            String
  description      String?
  status           TaskStatus     @default(TODO)
  priority         Priority       @default(MEDIUM)
  dueDate          DateTime?
  estimatedMinutes Int?
  actualMinutes    Int?           @default(0)
  creatorId        String?
  creator          User?          @relation("CreatedBy", fields: [creatorId], references: [id])
  assigneeId       String?
  assignee         User?          @relation("AssignedTo", fields: [assigneeId], references: [id])
  templateId       String?
  template         TaskTemplate?  @relation(fields: [templateId], references: [id])
  parentTaskId     String?
  parentTask       Task?          @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks         Task[]         @relation("SubTasks")
  tags             String[]
  recurrence       Json?          // Recurrence rule: { rule: "NONE" | "DAILY" | "WEEKLY" | "MONTHLY", interval?: number, nextDue?: DateTime }
  checklistItems   Json?          // Array of checklist items: { text: string, completed: boolean }[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // New fields
  department       String         @default("General")
  frequency        Frequency      @default(ONE_TIME)
  customFrequency  String?
  progress         Int            @default(0)
  isSubtask        Boolean        @default(false)

  // Relations
  attachments      TaskAttachment[]
  comments         TaskComment[]
  reminderSettings TaskReminder?
  updates          TaskUpdate[]
  timers           TaskTimer[]
  activities       Activity[]

  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([creatorId])
}

model TaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  url        String
  filename   String
  uploadedBy String
  uploadedAt DateTime @default(now())
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model TaskReminder {
  id                String   @id @default(cuid())
  taskId            String   @unique
  task              Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  beforeDueDate     Boolean
  onDueDate         Boolean
  recurring         Boolean
  emailNotification Boolean
  inAppNotification Boolean
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  performedBy String
  details     Json
  createdAt   DateTime @default(now())
}

model TaskTransfer {
  id            String   @id @default(cuid())
  taskId        String
  fromUserId    String
  toUserId      String
  transferredBy String
  transferredAt DateTime @default(now())
  reason        String
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  members     User[]
}

model TaskUpdate {
  id          String        @id @default(cuid())
  taskId      String
  task        Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  content     String
  type        UpdateType    @default(COMMENT)
  attachments Json?         // Array of attachment metadata: { name: string, size?: number, url?: string }
  createdAt   DateTime      @default(now())

  // Relations
  comments    TaskUpdateComment[]
}

model TaskUpdateComment {
  id           String     @id @default(cuid())
  taskUpdateId String
  taskUpdate   TaskUpdate @relation(fields: [taskUpdateId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  body         String
  createdAt    DateTime   @default(now())
}

model TaskTimer {
  id              String    @id @default(cuid())
  taskId          String
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  startedAt       DateTime
  stoppedAt       DateTime?
  durationMinutes Int       @default(0)
}

model TaskTemplate {
  id              String    @id @default(cuid())
  name            String
  description     String?
  defaultPriority Priority  @default(MEDIUM)
  checklistItems  Json?     // Array of checklist items: string[]
  createdById     String?
  createdBy       User?     @relation(fields: [createdById], references: [id])
  tasks           Task[]
  createdAt       DateTime  @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("INFO")
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model CalendarEvent {
  id        String    @id @default(cuid())
  title     String
  fromDate  DateTime
  toDate    DateTime
  time      String?   // Optional time string e.g. "14:30" for timed events
  type      EventType @default(EVENT)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([fromDate])
}

model Activity {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())
  taskId     String?
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

